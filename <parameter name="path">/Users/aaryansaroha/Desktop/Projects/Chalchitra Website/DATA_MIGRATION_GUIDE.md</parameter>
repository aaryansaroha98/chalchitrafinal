# How to Migrate Your Local Database to Render

## Problem
Your website shows but no data appears because:
- Your data is in `database.db` (local SQLite file)
- Render's server doesn't have this file
- You need to migrate data to Render's database

## Solution: Export Local Data and Import to Render

### Step 1: Export Your Local Data

Run these commands on your computer:

```bash
cd "/Users/aaryansaroha/Desktop/Projects/Chalchitra Website"

# Install sqlite3 if not installed
npm install -g sqlite3

# Export all data to JSON files
sqlite3 database.db ".dump movies" > movies_data.sql
sqlite3 database.db ".dump bookings" > bookings_data.sql
sqlite3 database.db ".dump users" > users_data.sql
sqlite3 database.db ".dump team" > team_data.sql
sqlite3 database.db ".dump gallery" > gallery_data.sql
sqlite3 database.db ".dump settings" > settings_data.sql
sqlite3 database.db ".dump foods" > foods_data.sql
sqlite3 database.db ".dump coupons" > coupons_data.sql
```

### Step 2: Check What's in Your Database

```bash
sqlite3 database.db "SELECT * FROM movies;"
sqlite3 database.db "SELECT COUNT(*) FROM movies;"
sqlite3 database.db "SELECT COUNT(*) FROM team;"
sqlite3 database.db "SELECT COUNT(*) FROM settings;"
```

### Step 3: Set Up Render PostgreSQL Database

1. Go to https://dashboard.render.com
2. Click "New +" → "PostgreSQL"
3. Name: `chalchitra-db`
4. Click "Create Database"
5. **Copy the "Connection String"** (starts with `postgres://...`)

### Step 4: Add DATABASE_URL to Render

1. Go to your Web Service on Render
2. Click "Environment"
3. Add:
   - Key: `DATABASE_URL`
   - Value: `postgres://...` (from step 3)
4. Click "Save Changes"

### Step 5: Connect to Render Database and Import Data

**Option A: Using Render's psql command**

1. In Render dashboard, click "Connect" for your PostgreSQL
2. Run:
```bash
psql "postgres://user:pass@host:5432/database" -f movies_data.sql
```

**Option B: Using a migration script**

Create `migrate-to-render.js`:
```javascript
const fs = require('fs');
const sqlite3 = require('sqlite3').verbose();
const { Client } = require('pg');

// Your Render database connection string
const connectionString = process.env.DATABASE_URL;

async function migrate() {
  // Read local database
  const db = new sqlite3.Database('./database.db');
  
  // Connect to PostgreSQL
  const pgClient = new Client({ connectionString });
  await pgClient.connect();
  
  // Get all tables
  const tables = ['movies', 'bookings', 'users', 'team', 'gallery', 'settings', 'foods', 'coupons'];
  
  for (const table of tables) {
    console.log(`Migrating ${table}...`);
    
    // Get data from SQLite
    const rows = await new Promise((resolve, reject) => {
      db.all(`SELECT * FROM ${table}`, (err, rows) => {
        if (err) reject(err);
        else resolve(rows);
      });
    });
    
    // Insert into PostgreSQL
    for (const row of rows) {
      const columns = Object.keys(row).join(', ');
      const values = Object.values(row).map((v, i) => `$${i + 1}`).join(', ');
      const query = `INSERT INTO ${table} (${columns}) VALUES (${values})`;
      
      try {
        await pgClient.query(query, Object.values(row));
      } catch (err) {
        console.log(`Error inserting into ${table}:`, err.message);
      }
    }
    
    console.log(`Migrated ${rows.length} rows from ${table}`);
  }
  
  await pgClient.end();
  db.close();
  console.log('Migration complete!');
}

migrate().catch(console.error);
```

Run:
```bash
npm install pg
DATABASE_URL="postgres://..." node migrate-to-render.js
```

### Step 6: Create Database Tables on Render

Create `init-db.js` for Render:
```javascript
const { Client } = require('pg');
const connectionString = process.env.DATABASE_URL;

const client = new Client({ connectionString });

const createTables = `
-- Create tables (adapted from your SQLite schema)
CREATE TABLE IF NOT EXISTS movies (
  id SERIAL PRIMARY KEY,
  title TEXT,
  description TEXT,
  poster_url TEXT,
  date TEXT,
  venue TEXT,
  price REAL,
  available_foods TEXT,
  category TEXT,
  duration TEXT,
  imdb_rating TEXT,
  language TEXT,
  is_upcoming INTEGER DEFAULT 1,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS users (
  id SERIAL PRIMARY KEY,
  google_id TEXT UNIQUE,
  email TEXT UNIQUE,
  name TEXT,
  is_admin INTEGER DEFAULT 0,
  code_scanner INTEGER DEFAULT 0,
  admin_tag TEXT
);

CREATE TABLE IF NOT EXISTS team (
  id SERIAL PRIMARY KEY,
  name TEXT,
  student_id TEXT,
  photo_url TEXT,
  role TEXT,
  section TEXT DEFAULT 'current_team',
  scanner_access INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS gallery (
  id SERIAL PRIMARY KEY,
  image_url TEXT,
  event_name TEXT,
  uploaded_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS settings (
  id INTEGER PRIMARY KEY,
  tagline TEXT,
  hero_background TEXT,
  hero_background_image TEXT,
  hero_background_video TEXT,
  about_text TEXT,
  about_image TEXT,
  contact_head_name TEXT,
  contact_head_email TEXT
);

CREATE TABLE IF NOT EXISTS bookings (
  id SERIAL PRIMARY KEY,
  user_id INTEGER,
  movie_id INTEGER,
  num_people INTEGER,
  food_option TEXT,
  coupon_code TEXT,
  total_price REAL,
  discount_amount REAL,
  payment_method TEXT,
  payment_id TEXT,
  payment_amount REAL,
  payment_order_id TEXT,
  payment_status TEXT,
  qr_code TEXT UNIQUE,
  selected_seats TEXT,
  is_used INTEGER DEFAULT 0,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS foods (
  id SERIAL PRIMARY KEY,
  name TEXT NOT NULL,
  description TEXT,
  price REAL NOT NULL,
  category TEXT,
  image_url TEXT,
  is_available INTEGER DEFAULT 1,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE IF NOT EXISTS coupons (
  id SERIAL PRIMARY KEY,
  code TEXT UNIQUE,
  description TEXT,
  discount_type TEXT CHECK(discount_type IN ('percentage', 'fixed')),
  discount_value REAL,
  min_purchase REAL DEFAULT 0,
  max_discount REAL,
  usage_limit INTEGER,
  used_count INTEGER DEFAULT 0,
  expiry_date DATETIME,
  is_active INTEGER DEFAULT 1,
  created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
  updated_at DATETIME DEFAULT CURRENT_TIMESTAMP
);
`;

async function init() {
  await client.connect();
  await client.query(createTables);
  console.log('Database tables created!');
  await client.end();
}

init().catch(console.error);
```

Run on Render:
```bash
npm install pg
DATABASE_URL="postgres://..." node init-db.js
```

### Step 7: Restart Render Service

1. Go to Render dashboard
2. Click your web service
3. Click "Deploys" → "Trigger deploy" → "Deploy latest commit"

