# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=development
PORT=3000
DATABASE_PATH=./database.db

# Session Secret (use a random string)
SESSION_SECRET=your-random-secret-key-here

# ===========================================
# GOOGLE OAUTH CREDENTIALS
# Get from: https://console.cloud.google.com/apis/credentials
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ===========================================
# COIN SYSTEM (No payment gateway - fully coin-based)
# ===========================================

# ===========================================
# EMAIL CONFIGURATION (Brevo HTTP API)
# Get API key from: https://app.brevo.com/settings/keys/api
# Also set in Render dashboard for production
# ===========================================
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=chalchitra@iitjammu.ac.in

# ===========================================
# URLS
# ===========================================
# For local development:
FRONTEND_URL=http://localhost:3000

# For Production (update these after deployment):
# BACKEND_URL=https://your-app.onrender.com
# FRONTEND_URL=https://your-app.netlify.app
